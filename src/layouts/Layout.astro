---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Sol Spy | Solana Spy" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Google Fonts for premium cyberpunk/hacker typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

    <!-- Telegram Web App SDK -->
    <script src="https://telegram.org/js/telegram-web-app.js" is:inline></script>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-sans antialiased selection:bg-emerald-500 selection:text-slate-950 overflow-x-hidden pb-safe">
    <!-- Ambient glowing backdrop effect -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
      <div class="absolute -top-[40%] -left-[30%] w-[80%] h-[80%] rounded-full bg-emerald-500/10 blur-[120px]"></div>
      <div class="absolute -bottom-[20%] -right-[20%] w-[70%] h-[70%] rounded-full bg-emerald-500/5 blur-[100px]"></div>
    </div>

    <!-- Main Content Container -->
    <div class="relative z-10 flex flex-col min-h-screen w-full max-w-xl mx-auto">
      <slot />
    </div>

    <style is:global>
      :root {
        font-family: 'Outfit', sans-serif;
        color-scheme: dark;
      }
      
      /* Monospace numbers/codes */
      .font-mono {
        font-family: 'JetBrains Mono', monospace;
      }

      /* Custom scrollbar styling for sleek premium hacker UI */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: rgba(15, 23, 42, 0.6);
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(16, 185, 129, 0.2);
        border-radius: 9999px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(16, 185, 129, 0.4);
      }

      /* Safe area padding helper for modern mobile notches */
      .pb-safe {
        padding-bottom: calc(env(safe-area-inset-bottom) + 1rem);
      }
    </style>
  </body>
</html>
